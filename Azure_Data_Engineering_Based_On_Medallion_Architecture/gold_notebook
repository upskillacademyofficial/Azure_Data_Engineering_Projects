2.Total Revenue by State
Which states generate the most revenue?
%sql  -- USING SQL
CREATE OR REPLACE TABLE gold_catalog.business_metrics.revenue_by_state AS
SELECT 
    ds.state,
    SUM(fs.total_amount) AS total_revenue
FROM gold_catalog.analytics.fact_sales fs
JOIN gold_catalog.analytics.dim_stores ds
    ON fs.store_id = ds.store_id
GROUP BY ds.state
ORDER BY total_revenue DESC;                              
