1. Sales by Category
Which category performs best?
# using spark.sql
sales_by_categogry = spark.sql("""
  SELECT
    p.category_name,
    SUM(f.total_amount) AS category_sales
  FROM gold_catalog.analytics.fact_sales f
  JOIN gold_catalog.analytics.dim_products p
    ON f.product_id = p.product_id
  GROUP BY p.category_name
  ORDER BY category_sales DESC
  """)

# Write to gold layer
sales_by_categogry.write.format("delta") \
    .mode("overwrite") \
    .saveAsTable("gold_catalog.business_metrics.sales_by_categogry")
