4. FACT CUSTOMER BEHAVIOR (CART VS SALES)
from pyspark.sql.functions import sum, col

#  FACT CUSTOMER BEHAVIOR (CART VS SALES)
from pyspark.sql.functions import sum, col

# 1. Aggregate carts data at customer level
carts_agg = api_carts.groupBy("customer_id") \
    .agg(
        sum("total_products").alias("carts_total_products"),
        sum("carts_total").alias("carts_total_amount")
    )

# 2. Aggregate sales data at customer level
sales_agg = sales_transactions.groupBy("customer_id") \
    .agg(
        sum("quantity").alias("sales_quantity"),
        sum("total_amount").alias("sales_total_amount")
    )

# 3. Join (LEFT JOIN - keep all cart behavior)
fact_customer_behavior = carts_agg.join(
    sales_agg,
    "customer_id",
    "left"
).withColumn(
    "conversion_rate",
    col("sales_quantity") / col("carts_total_products")
)

# display(fact_customer_behavior)

# save data into gold layer
fact_customer_behavior.write.format("delta").mode("overwrite").saveAsTable("gold_catalog.analytics.fact_customer_behavior")
